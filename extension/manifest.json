{
  "manifest_version": 3,

  "name": "Coworker",

  "version": "1.0.0",

  "description": "Helps you learn concepts of data structures and algorithms on the go!",

  "permissions": [
    "sidePanel",
    "storage",
    "scripting"
  ],

  "side_panel":{
    "default_path": "./sidebar/sidebar.html "
  },

  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:5500/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],

      "js": [
        "content.js"
      ],
      
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "Launch Coworker"
  },
  
   "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}