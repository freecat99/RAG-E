{
  "manifest_version": 3,
  "name": "Coworker",
  "version": "1.0.0",
  "description": "Helps you learn concepts of data structures and algorithms on the go!",

  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://leetcode.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "index.html"
  },

  "action": {
    "default_title": "Open Coworker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}